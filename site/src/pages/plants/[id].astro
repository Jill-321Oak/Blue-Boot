---
import Base from '../../layouts/Base.astro';
import { getAllPlants, type Plant } from '../../lib/plants';

export function getStaticPaths() {
  return getAllPlants().map(plant => ({
    params: { id: plant.id },
    props: { plant },
  }));
}

interface Props { plant: Plant }
const { plant } = Astro.props;

function layerLabel(layer: string): string {
  const labels: Record<string, string> = {
    canopy: 'Canopy', understory: 'Understory', shrub: 'Shrub',
    herbaceous: 'Herbaceous', groundCover: 'Ground Cover', vine: 'Vine',
    root: 'Root', fungal: 'Fungal',
  };
  return labels[layer] ?? layer;
}
---

<Base title={`${plant.name.commonName[0]} — Plant Database`} description={`Profile for ${plant.name.latinName}: ${plant.description.height} ${plant.permaculture.layer.primary} layer plant.`}>

  <a href="/browse" class="back">&larr; Browse all plants</a>

  <div class="header">
    <h1>{plant.name.commonName[0]}</h1>
    <p class="latin"><em>{plant.name.latinName}</em></p>
    {plant.name.commonName.length > 1 && (
      <p class="aliases">Also: {plant.name.commonName.slice(1).join(', ')}</p>
    )}
  </div>

  <div class="info-grid">
    <div class="info-item"><span class="label">Family</span><span>{plant.name.family}</span></div>
    <div class="info-item"><span class="label">Layer</span><span>{layerLabel(plant.permaculture.layer.primary)}</span></div>
    {plant.range.zone.min != null && (
      <div class="info-item"><span class="label">Zone</span><span>{plant.range.zone.description}</span></div>
    )}
    <div class="info-item"><span class="label">Maintenance</span><span>{plant.maintenance.maintenanceLevel}</span></div>
  </div>

  <h2>Description</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Height</span><span>{plant.description.height}</span></div>
    <div class="info-item"><span class="label">Spread</span><span>{plant.description.spread}</span></div>
    <div class="info-item"><span class="label">Spacing</span><span>{plant.description.spacing}</span></div>
    <div class="info-item"><span class="label">Growth Rate</span><span>{plant.description.growthRate}</span></div>
    <div class="info-item"><span class="label">Time to Maturity</span><span>{plant.description.timeToMaturity}</span></div>
    <div class="info-item"><span class="label">Lifespan</span><span>{plant.description.lifespan}</span></div>
    <div class="info-item"><span class="label">Type</span><span>{plant.description.deciduousEvergreen}</span></div>
    {plant.description.winterInterest && (
      <div class="info-item"><span class="label">Winter Interest</span><span>{plant.description.winterInterest}</span></div>
    )}
  </div>

  <h2>Range & Hardiness</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Native Range</span><span>{plant.range.nativeRange}</span></div>
    <div class="info-item"><span class="label">US Native</span><span>{plant.range.usNativeStatus.native ? 'Yes' : 'No'} — {plant.range.usNativeStatus.description}</span></div>
    <div class="info-item"><span class="label">Invasive</span><span>{plant.range.invasive.invasive ? 'Yes' : 'No'} — {plant.range.invasive.description}</span></div>
  </div>

  <h2>Light & Water</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Sun</span><span>{plant.lightAndWater.sun}</span></div>
    <div class="info-item"><span class="label">Water</span><span>{plant.lightAndWater.water}</span></div>
    <div class="info-item"><span class="label">Drainage</span><span>{plant.lightAndWater.drainagePreference.description}</span></div>
    {plant.lightAndWater.drainagePreference.claySoilPerformance && (
      <div class="info-item"><span class="label">Clay Performance</span><span>{plant.lightAndWater.drainagePreference.claySoilPerformance.description}</span></div>
    )}
  </div>

  <h2>Soil</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">pH</span><span>{plant.soil.phRange.description}</span></div>
    <div class="info-item"><span class="label">Texture</span><span>{plant.soil.texturePreference}</span></div>
    <div class="info-item"><span class="label">Root Character</span><span>{plant.soil.rootCharacter}</span></div>
  </div>

  <h2>Bloom</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Bloom Time</span><span>{plant.bloom.bloomTime}</span></div>
    <div class="info-item"><span class="label">Description</span><span>{plant.bloom.bloomDescription}</span></div>
    <div class="info-item"><span class="label">Fragrance</span><span>{plant.bloom.fragrance}</span></div>
    <div class="info-item"><span class="label">Flower Type</span><span>{plant.bloom.flowerSex}</span></div>
    <div class="info-item"><span class="label">Pollination</span><span>{plant.bloom.pollination}</span></div>
  </div>

  <h2>Yield</h2>
  <div class="info-grid">
    {plant.yield.edibleParts && <div class="info-item"><span class="label">Edible Parts</span><span>{plant.yield.edibleParts}</span></div>}
    {plant.yield.harvestSeason && <div class="info-item"><span class="label">Harvest Season</span><span>{plant.yield.harvestSeason}</span></div>}
    {plant.yield.medicinalUses && <div class="info-item"><span class="label">Medicinal Uses</span><span>{plant.yield.medicinalUses}</span></div>}
    {plant.yield.craftOtherYield && <div class="info-item"><span class="label">Craft / Other</span><span>{plant.yield.craftOtherYield}</span></div>}
  </div>

  <h2>Cautions & Hazards</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Thorns/Spines</span><span>{plant.cautionsAndHazards.thornsSpines ? 'Yes' : 'No'}</span></div>
    {plant.cautionsAndHazards.toxicityPeople && <div class="info-item"><span class="label">Toxicity (People)</span><span>{plant.cautionsAndHazards.toxicityPeople}</span></div>}
    {plant.cautionsAndHazards.toxicityAnimals && <div class="info-item"><span class="label">Toxicity (Animals)</span><span>{plant.cautionsAndHazards.toxicityAnimals}</span></div>}
    {plant.cautionsAndHazards.allelopathy && <div class="info-item"><span class="label">Allelopathy</span><span>{plant.cautionsAndHazards.allelopathy}</span></div>}
    {plant.cautionsAndHazards.notes && <div class="info-item"><span class="label">Notes</span><span>{plant.cautionsAndHazards.notes}</span></div>}
  </div>

  <h2>Permaculture</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Layer</span><span>{plant.permaculture.layer.description}</span></div>
    <div class="info-item"><span class="label">Coppiceable</span><span>{plant.permaculture.coppiceable ? 'Yes' : 'No'}</span></div>
    <div class="info-item"><span class="label">Roles</span><span>{plant.permaculture.roles.join(', ')}</span></div>
    {plant.permaculture.companionPlants.length > 0 && (
      <div class="info-item"><span class="label">Companion Plants</span><span>{plant.permaculture.companionPlants.join(', ')}</span></div>
    )}
    {plant.permaculture.antagonists.length > 0 && (
      <div class="info-item"><span class="label">Antagonists</span><span>{plant.permaculture.antagonists.join(', ')}</span></div>
    )}
  </div>

  <h2>Wildlife</h2>
  <div class="info-grid">
    {plant.wildlife.attracts && <div class="info-item"><span class="label">Attracts</span><span>{plant.wildlife.attracts}</span></div>}
    {plant.wildlife.hostPlantFor && <div class="info-item"><span class="label">Host Plant For</span><span>{plant.wildlife.hostPlantFor}</span></div>}
    {plant.wildlife.nestingHabitat && <div class="info-item"><span class="label">Nesting Habitat</span><span>{plant.wildlife.nestingHabitat}</span></div>}
  </div>

  <h2>Tolerances</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Deer</span><span>{plant.tolerances.deer?.description}</span></div>
    <div class="info-item"><span class="label">Salt</span><span>{plant.tolerances.salt?.description}</span></div>
    <div class="info-item"><span class="label">Drought</span><span>{plant.tolerances.drought?.description}</span></div>
    {plant.tolerances.other && (
      <div class="info-item"><span class="label">Other</span><span>{plant.tolerances.other}</span></div>
    )}
  </div>

  <h2>Maintenance</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Level</span><span>{plant.maintenance.maintenanceLevel}</span></div>
    <div class="info-item"><span class="label">Pruning</span><span>{plant.maintenance.pruningNotes}</span></div>
    {plant.maintenance.propagationMethods.length > 0 && (
      <div class="info-item"><span class="label">Propagation</span><span>{plant.maintenance.propagationMethods.join(', ')}</span></div>
    )}
  </div>

  {plant.cultivarNotes && (
    <>
      <h2>Cultivar Notes</h2>
      <div class="info-grid">
        <div class="info-item"><span class="label">Notes</span><span>{plant.cultivarNotes}</span></div>
      </div>
    </>
  )}

  <h2>Garden Use</h2>
  <div class="info-grid">
    <div class="info-item"><span class="label">Suggested Use</span><span>{plant.gardenUse.suggestedUse.join(', ')}</span></div>
    {plant.gardenUse.designPlacement && <div class="info-item"><span class="label">Design Placement</span><span>{plant.gardenUse.designPlacement}</span></div>}
    {plant.gardenUse.acquisitionStatus && <div class="info-item"><span class="label">Acquisition Status</span><span>{plant.gardenUse.acquisitionStatus}</span></div>}
  </div>

  <h2>Links</h2>
  <div class="links">
    {plant.links.wikipedia && <a href={plant.links.wikipedia} target="_blank" rel="noopener">Wikipedia</a>}
    {plant.links.inaturalist && <a href={plant.links.inaturalist} target="_blank" rel="noopener">iNaturalist</a>}
    {plant.links.missouriBotanicalGarden?.map(link => (
      <a href={link.url} target="_blank" rel="noopener">MBG: {link.label}</a>
    ))}
  </div>

</Base>

<style>
  .back {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .back:hover { text-decoration: underline; }

  .header { margin-bottom: 1.5rem; }
  .latin { font-size: 1.1rem; color: var(--color-muted); }
  .aliases { font-size: 0.9rem; color: var(--color-muted); margin-top: 0.25rem; }

  .info-grid {
    display: grid;
    gap: 0.75rem;
  }
  .info-item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 0.75rem;
    font-size: 0.95rem;
  }
  .info-item .label {
    font-weight: 600;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .links a {
    font-size: 0.9rem;
    text-decoration: none;
  }
  .links a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .info-item {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
